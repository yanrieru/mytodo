{
  "expo": {
    "name": "MyTodo App",
    "slug": "mytodo_app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/mytodo.png",
    "scheme": "mytodoapp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "image": "./assets/images/mytodo.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "windowSoftInputMode": "adjustResize",
      "package": "com.yanrieru.mytodoapp"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/mytodointro.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "9468465a-0976-4b2f-ad79-68ae1e4a95fc"
      }
    },
    "owner": "yanrieru"
  }
}
